# Απαιτείται — δημιούργησε τυχαίο κλειδί (π.χ. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=change-me-before-deploy

DJANGO_DEBUG=false

# Hostnames / IPs που επιτρέπονται (χωρισμένα με κόμμα, χωρίς κενά)
# Για Tailscale αργότερα: πρόσθεσε MagicDNS hostname, Tailscale IP (100.x.x.x), .ts.net
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Μόνο αν τερματίζεις HTTPS μπροστά (π.χ. reverse proxy / Tailscale Serve)
# CSRF_TRUSTED_ORIGINS=https://your-host.example.com
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true

# Demo δεδομένα — ΜΟΝΟ για τοπικό/dev, ποτέ σε παραγωγή
SEED_DEMO=false

# Θύρα host (docker compose)
WEB_PORT=8000

# Στοιχεία εταιρείας (PDF προσφοράς) — ρυθμίζονται κυρίως από Διαχείριση → Στοιχεία εταιρείας
COMPANY_NAME=Vibe Electrician
COMPANY_TAGLINE=Ηλεκτρολογικές Εγκαταστάσεις
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_VAT=
COMPANY_WEBSITE=
